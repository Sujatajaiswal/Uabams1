# Local database used by the backend. SQLite needs no separate server.
# If you omit this variable, the app uses your OS temp folder:
# C:/Users/<you>/AppData/Local/Temp/uabams-cloud/uabams.db on Windows.
DATABASE_URL=sqlite:///C:/Users/Pilabs/AppData/Local/Temp/uabams-cloud/uabams.db

# Original gateway ZIPs and extracted binary files are preserved here.
ARCHIVE_STORAGE_DIR=C:/Users/Pilabs/AppData/Local/Temp/uabams-cloud/archives

# Cloud/PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://uabams:uabams@localhost:5432/uabams

# CORS - comma separated list of allowed origins, "*" for demo
CORS_ORIGINS=*

# Default sampling rate sent to gateways via /api/v1/config (Hz)
DEFAULT_SAMPLING_RATE=2500

# Gateway considered OFFLINE if no upload received within this many seconds
GATEWAY_OFFLINE_AFTER_SECONDS=300

# Seed the database with demo data on startup (true/false)
SEED_ON_STARTUP=true
